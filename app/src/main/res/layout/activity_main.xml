<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Zeile 1: Hamburger + Section-Tabs + Add Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/nav_tab_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnMenu"
                style="@style/NavButton"
                android:minWidth="44dp"
                android:text="☰"
                android:textSize="18sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/nav_border" />

            <HorizontalScrollView
                android:id="@+id/sectionTabsScroll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/sectionTabsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnAddSection"
                style="@style/NavButton"
                android:text="@string/btn_add_section" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/nav_border" />

        <!-- Zeile 2: Werkzeuge -->
        <HorizontalScrollView
            android:id="@+id/toolBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/nav_list_bg"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="8dp"
                android:paddingRight="8dp">

                <Button
                    android:id="@+id/btnDragHandle"
                    style="@style/NavButton"
                    android:minWidth="36dp"
                    android:text="⋮⋮"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnToolPen"
                    style="@style/NavButton"
                    android:text="✏ Stift" />

                <Button
                    android:id="@+id/btnToolHighlighter"
                    style="@style/NavButton"
                    android:text="🖍 Marker" />

                <Button
                    android:id="@+id/btnToolLine"
                    style="@style/NavButton"
                    android:text="📏 Linie" />

                <Button
                    android:id="@+id/btnToolText"
                    style="@style/NavButton"
                    android:text="T Text" />

                <Button
                    android:id="@+id/btnToolImage"
                    style="@style/NavButton"
                    android:text="🖼 Bild" />

                <Button
                    android:id="@+id/btnToolEraser"
                    style="@style/NavButton"
                    android:text="🧽 Radierer" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/nav_border"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp" />

                <LinearLayout
                    android:id="@+id/colorPaletteContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/nav_border"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btnWidthThin"
                    style="@style/NavButton"
                    android:minWidth="36dp"
                    android:text="●"
                    android:textSize="9sp" />

                <Button
                    android:id="@+id/btnWidthMed"
                    style="@style/NavButton"
                    android:minWidth="36dp"
                    android:text="●"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnWidthThick"
                    style="@style/NavButton"
                    android:minWidth="36dp"
                    android:text="●"
                    android:textSize="20sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/nav_border"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btnPaper"
                    style="@style/NavButton"
                    android:text="@string/paper_blank" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/nav_border"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btnUndo"
                    style="@style/NavButton"
                    android:text="@string/btn_undo" />

                <Button
                    android:id="@+id/btnRedo"
                    style="@style/NavButton"
                    android:text="@string/btn_redo" />

                <Button
                    android:id="@+id/btnClear"
                    style="@style/NavButton"
                    android:text="@string/btn_clear" />
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:id="@+id/toolBarDividerBottom"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/nav_border" />

        <!-- Content: Page-Liste links, Canvas rechts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="@color/nav_list_bg"
                android:orientation="vertical">

                <ScrollView
                    android:id="@+id/pageListScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/pageListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />
                </ScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/nav_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAddPage"
                        style="@style/NavButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="@string/btn_add_page" />

                    <Button
                        android:id="@+id/btnAddSubpage"
                        style="@style/NavButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="@string/btn_add_subpage" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/nav_border" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <com.inktest.InkView
                    android:id="@+id/inkView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/metricsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="12dp"
                    android:background="@color/panel_bg_translucent"
                    android:fontFamily="monospace"
                    android:padding="10dp"
                    android:textColor="@color/panel_text"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Linker App-Menü-Drawer -->
    <ScrollView
        android:id="@+id/appMenuPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/panel_bg"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/btnAppMenuClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:minWidth="40dp"
                android:minHeight="40dp"
                android:background="@android:color/transparent"
                android:textColor="@color/panel_text"
                android:textSize="18sp"
                android:text="✕" />

            <TextView
                style="@style/PanelLabel"
                android:text="Darstellung" />

            <TextView
                android:id="@+id/menuPaper"
                style="@style/MenuItem"
                android:text="Papier-Stil …" />

            <TextView
                android:id="@+id/menuFloatToolbar"
                style="@style/MenuItem"
                android:text="Werkzeugleiste freistellen" />

            <TextView
                style="@style/MenuItemDisabled"
                android:text="Theme (Phase 6)" />

            <TextView
                style="@style/PanelLabel"
                android:layout_marginTop="24dp"
                android:text="Diagnose" />

            <TextView
                android:id="@+id/menuMetrics"
                style="@style/MenuItem"
                android:text="Metrics-Overlay anzeigen" />

            <TextView
                android:id="@+id/menuTuning"
                style="@style/MenuItem"
                android:text="Engine-Tuning …" />

            <TextView
                style="@style/PanelLabel"
                android:layout_marginTop="24dp"
                android:text="Sync" />

            <TextView
                android:id="@+id/menuSyncNow"
                style="@style/MenuItem"
                android:text="Jetzt synchronisieren" />

            <TextView
                android:id="@+id/menuSyncSettings"
                style="@style/MenuItem"
                android:text="WebDAV-Einstellungen …" />

            <TextView
                android:id="@+id/menuSchoolYear"
                style="@style/MenuItem"
                android:text="Aktives Schuljahr …" />

            <TextView
                style="@style/PanelLabel"
                android:layout_marginTop="24dp"
                android:text="System" />

            <TextView
                android:id="@+id/menuReset"
                style="@style/MenuItem"
                android:text="Auf Defaults zurücksetzen" />
        </LinearLayout>
    </ScrollView>

    <!-- Rechter Engine-Tuning-Drawer (unverändert im Aufbau, Farb-Radio entfernt) -->
    <ScrollView
        android:id="@+id/tuningPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/panel_bg"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/btnTuningClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:minWidth="40dp"
                android:minHeight="40dp"
                android:background="@android:color/transparent"
                android:textColor="@color/panel_text"
                android:textSize="18sp"
                android:text="✕" />

            <TextView
                android:id="@+id/labelWidth"
                style="@style/PanelLabel"
                android:text="@string/tuning_width" />

            <SeekBar
                android:id="@+id/sliderWidth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/labelSmooth"
                style="@style/PanelLabel"
                android:text="@string/tuning_smooth" />

            <SeekBar
                android:id="@+id/sliderSmooth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                style="@style/PanelLabel"
                android:text="@string/tuning_algo" />

            <RadioGroup
                android:id="@+id/algoGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/algoBezier"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_algo_bezier" />

                <RadioButton
                    android:id="@+id/algoCatmull"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_algo_catmull" />

                <RadioButton
                    android:id="@+id/algoWma"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_algo_wma" />
            </RadioGroup>

            <TextView
                style="@style/PanelLabel"
                android:text="@string/tuning_prediction" />

            <RadioGroup
                android:id="@+id/predictionGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/predictionOff"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_prediction_off" />

                <RadioButton
                    android:id="@+id/predictionAndroid"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_prediction_android" />

                <RadioButton
                    android:id="@+id/predictionLinear"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_prediction_linear" />
            </RadioGroup>

            <TextView
                style="@style/PanelLabel"
                android:text="@string/tuning_layer" />

            <RadioGroup
                android:id="@+id/layerGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/layerNone"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_layer_none" />

                <RadioButton
                    android:id="@+id/layerHardware"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_layer_hardware" />

                <RadioButton
                    android:id="@+id/layerSoftware"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_layer_software" />
            </RadioGroup>

            <TextView
                style="@style/PanelLabel"
                android:text="@string/tuning_bitmap" />

            <RadioGroup
                android:id="@+id/bitmapGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/bitmapArgb"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_bitmap_argb" />

                <RadioButton
                    android:id="@+id/bitmapRgb"
                    style="@style/PanelRadio"
                    android:text="@string/tuning_bitmap_rgb" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/toggleAntialias"
                style="@style/PanelCheck"
                android:text="@string/tuning_antialias" />

            <CheckBox
                android:id="@+id/toggleClipping"
                style="@style/PanelCheck"
                android:text="@string/tuning_clipping" />

            <CheckBox
                android:id="@+id/toggleDamageRect"
                style="@style/PanelCheck"
                android:text="@string/tuning_damage" />

            <CheckBox
                android:id="@+id/toggleUnbuffered"
                style="@style/PanelCheck"
                android:text="@string/tuning_unbuffered" />

            <Button
                android:id="@+id/btnReset"
                style="@style/PanelButton"
                android:layout_marginTop="20dp"
                android:text="@string/btn_reset" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
